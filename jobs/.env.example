# --- Database (same DB as the server) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=taskminder

# In GCP:
# DB_INSTANCE_CONNECTION_NAME=my-project:us-central1:taskminder-sql

# --- SMTP (Gmail app password, SendGrid SMTP, Mailgun, etc.) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-user@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="TaskMinder <your-user@gmail.com>"

# Admin email to receive expiry alerts
ADMIN_EMAIL=alonagabrus@gmail.com

# How many days ahead to look for expiring packages
REMINDER_HORIZON_DAYS=7
