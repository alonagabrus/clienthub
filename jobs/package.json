{
  "name": "taskminder-reminder-job",
  "version": "1.0.0",
  "description": "Cloud Function that sends reminder emails for upcoming tasks",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "functions-framework --target=sendReminders --source=dist",
    "dev": "ts-node-dev --respawn --transpile-only --exec \"npx functions-framework --target=sendReminders --source=src\" src/index.ts"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^3.4.0",
    "nodemailer": "^6.9.14",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.15",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
